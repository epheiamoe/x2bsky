APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

BSKY_HANDLE=your.bsky.handle
BSKY_PASSWORD=your_app_password
BSKY_APP_PASSWORD=your_app_password

X_CONSUMER_KEY=your_consumer_key
X_SECRET_KEY=your_secret_key
X_BEARER_TOKEN=your_bearer_token
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret
X_USER_ID=your_user_id

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_REQUIREPASS=your_redis_password

SECRET_KEY=generate_a_random_32_character_string

DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=x2bsky
DB_PASS=your_db_password
DB_NAME=x2bsky

BSKY_SESSION_DIR=/var/www/x2bsky/data

LOG_LEVEL=info
LOG_PATH=/var/www/x2bsky/logs

CRON_ENABLED=false
CRON_INTERVAL=5
