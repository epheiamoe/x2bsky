{
    "name": "x2bsky/x2bsky",
    "description": "X to Bluesky cross-poster",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-gd": "*"
    },
    "require-dev": {
        "abraham/twitteroauth": "^6.0",
        "predis/predis": "^2.2",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "X2BSky\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "platform": {
            "ext-fileinfo": "1.0"
        }
    }
}
